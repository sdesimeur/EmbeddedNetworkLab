<UserControl x:Class="EmbeddedNetworkLab.UI.Modules.TcpClient.TcpClientView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:EmbeddedNetworkLab.UI.Modules.TcpClient"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid Margin="20">
        <StackPanel>

            <TextBlock Text="TCP - Client"
                       FontSize="24"
                       Margin="0,0,0,15"
                       HorizontalAlignment="Center"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Center">
                <TextBlock Text="Target IP:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox Width="200"
                         Text="{Binding TargetAddress, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding IsConfigurationEditable}"/>

                <TextBlock Text="Port:" VerticalAlignment="Center" Margin="12,0,8,0"/>
                <!-- Bind direct to TargetPortText and filter input -->
                <TextBox Width="80"
                         Text="{Binding TargetPortText, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding IsConfigurationEditable}"
                         PreviewTextInput="Port_PreviewTextInput"
                         DataObject.Pasting="Port_Pasting"/>
            </StackPanel>

            <TextBlock Text="{Binding CurrentRate, StringFormat=Throughput: {0:F2} Mbps}"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,15"/>

            <Button Content="{Binding StartStopLabel}"
                    Command="{Binding ToggleCommand}"
                    IsEnabled="{Binding IsToggleEnabled}"
                    Width="120"
                    Height="30"/>

        </StackPanel>
    </Grid>
</UserControl>
