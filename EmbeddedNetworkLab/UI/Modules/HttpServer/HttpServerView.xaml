<UserControl x:Class="EmbeddedNetworkLab.UI.Modules.HttpServer.HttpServerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:EmbeddedNetworkLab.UI.Converters"
             mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BoolToBrushConverter x:Key="RunningBrush" TrueBrush="Green" FalseBrush="#333333"/>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="HTTP - Server" FontSize="18" FontWeight="Bold" Margin="0,0,0,16"/>

        <!-- Configuration + Controls -->
        <Border Grid.Row="1" Padding="12" Margin="0,0,0,12"
                BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Background="White">
            <StackPanel>
                <!-- Bind IP + HTTP Port -->
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Bind IP:" VerticalAlignment="Center" Grid.Column="0"/>
                    <ComboBox Grid.Column="1" Margin="0,0,8,0"
                              ItemsSource="{Binding NetworkInterfaces}"
                              SelectedItem="{Binding SelectedBindIp}"
                              IsEnabled="{Binding IsConfigurationEditable}"/>
                    <TextBlock Text="HTTP Port:" VerticalAlignment="Center" Grid.Column="2"/>
                    <TextBox Grid.Column="3" Margin="8,0,0,0"
                             Text="{Binding HttpPortText, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding IsConfigurationEditable}"/>
                </Grid>

                <!-- HTTPS Toggle + HTTPS Port -->
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="HTTPS:" VerticalAlignment="Center" Grid.Column="0"/>
                    <CheckBox Grid.Column="1" Margin="0,0,16,0"
                              IsChecked="{Binding HttpsEnabled}"
                              IsEnabled="{Binding IsConfigurationEditable}"
                              VerticalAlignment="Center"/>
                    <TextBlock Text="HTTPS Port:" VerticalAlignment="Center" Grid.Column="2"
                               IsEnabled="{Binding HttpsEnabled}"/>
                    <TextBox Grid.Column="3" Margin="8,0,0,0"
                             Text="{Binding HttpsPortText, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding HttpsEnabled}"/>
                    <TextBlock Grid.Column="4" Margin="16,0,0,0" VerticalAlignment="Center"
                               FontStyle="Italic" Foreground="#888" FontSize="11"
                               Text="HTTPS requires a certificate registered via: netsh http add sslcert"
                               Visibility="{Binding HttpsEnabled, Converter={StaticResource RunningBrush}}"/>
                </Grid>

                <!-- Start/Stop + Status -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Start" Width="80" Margin="0,0,8,0"
                            Command="{Binding StartCommand}"/>
                    <Button Grid.Column="1" Content="Stop" Width="80"
                            Command="{Binding StopCommand}"/>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                        <Ellipse Width="12" Height="12" Margin="0,0,8,0" VerticalAlignment="Center"
                                 Fill="{Binding IsRunning, Converter={StaticResource RunningBrush}}"/>
                        <TextBlock Text="{Binding ServerStatus}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Logs -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Received Videos -->
            <Border Grid.Column="0" Padding="8" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,6">
                        <TextBlock Text="Received Videos" FontWeight="Bold"/>
                        <Button HorizontalAlignment="Right" Content="Clear" Width="50" Height="20" FontSize="11"
                                Command="{Binding ClearVideosCommand}"/>
                    </Grid>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Videos}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="#EEE" BorderThickness="0,0,0,1" Padding="4,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="130"/>
                                                <ColumnDefinition Width="32"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding FileName}"
                                                       FontFamily="Consolas" FontSize="12"
                                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Grid.Column="1" Text="{Binding ReceivedAt}"
                                                       FontSize="11" Foreground="#888"
                                                       VerticalAlignment="Center" Margin="8,0"/>
                                            <Button Grid.Column="2" Content="&#9654;" Width="28" Height="24"
                                                    FontSize="12"
                                                    ToolTip="Play"
                                                    Command="{Binding PlayCommand}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Event Log -->
            <Border Grid.Column="2" Padding="8" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,6">
                        <TextBlock Text="Events" FontWeight="Bold"/>
                        <Button HorizontalAlignment="Right" Content="Clear" Width="50" Height="20" FontSize="11"
                                Command="{Binding ClearEventLogCommand}"/>
                    </Grid>
                    <ListBox x:Name="EventLogList"
                             Grid.Row="1"
                             ItemsSource="{Binding EventLog}"
                             FontFamily="Consolas" FontSize="11"
                             ScrollViewer.HorizontalScrollBarVisibility="Auto"
                             VirtualizingPanel.IsVirtualizing="True"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
