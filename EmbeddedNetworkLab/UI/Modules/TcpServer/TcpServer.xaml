<UserControl x:Class="EmbeddedNetworkLab.UI.Modules.TcpServer.TcpServer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EmbeddedNetworkLab.UI.Modules.TcpServer"
             xmlns:validation="clr-namespace:EmbeddedNetworkLab.UI.Validation"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="TCP - Server"
                       FontSize="24"
                       Margin="0,0,0,15"
                       HorizontalAlignment="Center"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,10" VerticalAlignment="Center">
                <TextBlock Text="Host IP:" VerticalAlignment="Center" Margin="10,5,8,5"/>
                <ComboBox Width="150"
                    ItemsSource="{Binding NetworkInterfaces}"
                    SelectedItem="{Binding SelectedBindIp}"
                    IsEnabled="{Binding IsConfigurationEditable}"/>
                <TextBlock Text="Port:" VerticalAlignment="Center" Margin="12,0,8,0"/>
                <!-- Bind direct to TargetPortText and filter input -->
                <TextBox Width="80"
                 Margin="5,0"
                 IsEnabled="{Binding IsConfigurationEditable}">
                    <TextBox.Text>
                        <Binding Path="BrokerPort" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged" ValidatesOnExceptions="True" NotifyOnValidationError="True">
                            <Binding.ValidationRules>
                                <validation:PortRangeValidationRule />
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox.Text>
                </TextBox>
            </StackPanel>

        </StackPanel>
    </Grid>
</UserControl>
