<UserControl x:Class="EmbeddedNetworkLab.UI.Modules.TestingModuleUi.TestingModuleUi"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:EmbeddedNetworkLab.UI.Modules.TestingModuleUi"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid Margin="20">
        <StackPanel>
            <TextBlock Text="Testing Module UI"
                       FontSize="24"
                       Margin="0,0,0,15"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="LiveCharts2"
                       FontSize="18"
                       Margin="0,0,0,15"
                       HorizontalAlignment="Left"/>
            <lvc:CartesianChart Height="250" Series="{Binding Series}" />
        </StackPanel>

    </Grid>
</UserControl>
