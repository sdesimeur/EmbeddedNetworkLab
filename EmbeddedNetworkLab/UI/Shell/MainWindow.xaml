<Window x:Class="EmbeddedNetworkLab.UI.Shell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EmbeddedNetworkLab"
        xmlns:vmThroughput="clr-namespace:EmbeddedNetworkLab.UI.Modules.Throughput"
        xmlns:viewThroughput="clr-namespace:EmbeddedNetworkLab.UI.Modules.Throughput"
        xmlns:vmMqtt="clr-namespace:EmbeddedNetworkLab.UI.Modules.MqttBroker"
        xmlns:viewMqtt="clr-namespace:EmbeddedNetworkLab.UI.Modules.MqttBroker"
        xmlns:vmSerial="clr-namespace:EmbeddedNetworkLab.UI.Modules.Serial"
        xmlns:viewSerial="clr-namespace:EmbeddedNetworkLab.UI.Modules.Serial"
        xmlns:vmSimulator="clr-namespace:EmbeddedNetworkLab.UI.Modules.SimulatorCentrale"
        xmlns:viewSimulator="clr-namespace:EmbeddedNetworkLab.UI.Modules.SimulatorCentrale"
        mc:Ignorable="d"
        Title="Embedded Network Lab" Height="800" Width="1000">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vmThroughput:ThroughputViewModel}">
            <viewThroughput:ThroughputView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmMqtt:MqttBrokerViewModel}">
            <viewMqtt:MqttBrokerView />
        </DataTemplate>

        <!-- Template for Serial views -->
        <DataTemplate DataType="{x:Type vmSerial:SerialViewModel}">
            <viewSerial:SerialView />
        </DataTemplate>

        <!-- Template for SimulatorCentrale -->
        <DataTemplate DataType="{x:Type vmSimulator:SimulatorCentraleViewModel}">
            <viewSimulator:SimulatorCentraleView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Main area (navigation, workspace, serial side-by-side) -->
            <RowDefinition Height="*" />
            <!-- Console -->
            <RowDefinition Height="150" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <!-- Navigation -->
            <ColumnDefinition Width="220" />
            <!-- Workspace -->
            <ColumnDefinition Width="*" />
            <!-- Serial links column -->
            <!-- <ColumnDefinition Width="520" /> -->
        </Grid.ColumnDefinitions>

        <!-- NAVIGATION PANEL -->
        <Border Grid.Row="0" Grid.Column="0" Background="#F3F3F3" BorderBrush="#DDDDDD" BorderThickness="0,0,1,1">
            <StackPanel Margin="10">
                <TextBlock Text="Modules" FontWeight="Bold" Margin="0,0,0,10"/>

                <TextBlock Text="MQTT" FontWeight="SemiBold" Margin="0,5,0,5"/>
                <Button Content="Broker" Margin="0,0,0,5" Command="{Binding OpenMqttBrokerCommand}"/>
                <Button Content="Client" Margin="0,0,0,10"/>

                <TextBlock Text="Network Tests" FontWeight="SemiBold" Margin="0,5,0,5"/>
                <Button Content="Throughput Test" Margin="0,0,0,5" Command="{Binding OpenThroughputCommand}"/>
                
                <TextBlock Text="Simulator" FontWeight="SemiBold" Margin="0,5,0,5"/>
                <Button Content="Centrale" Margin="0,0,0,5" Command="{Binding OpenSimulatorCentraleCommand}"/>
            </StackPanel>
        </Border>

        <!-- WORKSPACE -->
        <Border Grid.Row="0" Grid.Column="1" Background="White">
            <ContentControl Content="{Binding CurrentModule}" />
        </Border>

        <!-- SERIAL LINKS COLUMN -->
        <!-- 
        <Border Grid.Row="0" Grid.Column="2" Background="#FAFAFA" Padding="8" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Margin="4" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Background="White">
                    <ContentControl Content="{Binding LeftSerial}" />
                </Border>
            </Grid>
        </Border>
       -->

        <!-- CONSOLE -->
        <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
            Background="#1E1E1E">
            <TextBox 
                Foreground="LightGreen"
                Background="#1E1E1E"
                BorderThickness="0"
                FontFamily="Consolas"
                IsReadOnly="True"
                Text="{Binding ConsoleText}"
                TextWrapping="Wrap"
                VerticalScrollBarVisibility="Auto"
                Padding="10"
                AcceptsReturn="True"/>
        </Border>
    </Grid>
</Window>