<Window x:Class="EmbeddedNetworkLab.UI.Shell.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EmbeddedNetworkLab"
        xmlns:vmTcpClient="clr-namespace:EmbeddedNetworkLab.UI.Modules.TcpClient"
        xmlns:viewTcpClient="clr-namespace:EmbeddedNetworkLab.UI.Modules.TcpClient"
        xmlns:vmMqtt="clr-namespace:EmbeddedNetworkLab.UI.Modules.MqttBroker"
        xmlns:viewMqtt="clr-namespace:EmbeddedNetworkLab.UI.Modules.MqttBroker"
        xmlns:vmSerial="clr-namespace:EmbeddedNetworkLab.UI.Modules.Serial"
        xmlns:viewSerial="clr-namespace:EmbeddedNetworkLab.UI.Modules.Serial"
        xmlns:vmSimulator="clr-namespace:EmbeddedNetworkLab.UI.Modules.SimulatorCentrale"
        xmlns:viewSimulator="clr-namespace:EmbeddedNetworkLab.UI.Modules.SimulatorCentrale"
        xmlns:converters="clr-namespace:EmbeddedNetworkLab.UI.Converters"
        mc:Ignorable="d"
        Title="Embedded Network Lab" Height="800" Width="1000">

    <Window.Resources>
        <converters:BoolToBrushConverter x:Key="BoolToBrushConverter" TrueBrush="Green" FalseBrush="#333333"/>

        <DataTemplate DataType="{x:Type vmTcpClient:TcpClientViewModel}">
            <viewTcpClient:TcpClientView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vmMqtt:MqttBrokerViewModel}">
            <viewMqtt:MqttBrokerView />
        </DataTemplate>

        <!-- Template for Serial views -->
        <DataTemplate DataType="{x:Type vmSerial:SerialViewModel}">
            <viewSerial:SerialView />
        </DataTemplate>

        <!-- Template for SimulatorCentrale -->
        <DataTemplate DataType="{x:Type vmSimulator:SimulatorCentraleViewModel}">
            <viewSimulator:SimulatorCentraleView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Main area (navigation, workspace, serial side-by-side) -->
            <RowDefinition Height="*" />
            <!-- Console -->
            <RowDefinition Height="150" />
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <!-- Navigation -->
            <ColumnDefinition Width="220" />
            <!-- Workspace -->
            <ColumnDefinition Width="*" />
            <!-- Serial links column -->
            <!-- <ColumnDefinition Width="520" /> -->
        </Grid.ColumnDefinitions>

        <!-- NAVIGATION PANEL -->
        <Border Grid.Row="0" Grid.Column="0" Background="#F3F3F3" BorderBrush="#DDDDDD" BorderThickness="0,0,1,1">
            <StackPanel Margin="10">
                <TextBlock Text="Modules" FontWeight="Bold" Margin="0,0,0,10"/>

                <TextBlock Text="MQTT" FontWeight="SemiBold" Margin="0,5,0,5"/>
                <Button Margin="0,0,0,5" Command="{Binding OpenMqttBrokerCommand}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Broker" VerticalAlignment="Center"/>
                        <Ellipse Width="12" Height="12" Margin="8,0,0,0" VerticalAlignment="Center"
                                 Fill="{Binding MqttBrokerModule.IsRunning, Converter={StaticResource BoolToBrushConverter}}"/>
                    </StackPanel>
                </Button>
                <Button Content="Client" Margin="0,0,0,10"/>

                <TextBlock Text="TCP" FontWeight="SemiBold" Margin="0,5,0,5"/>
                <Button Margin="0,0,0,5" Command="{Binding OpenTcpServerCommand}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Server" VerticalAlignment="Center"/>
                        <Ellipse Width="12" Height="12" Margin="8,0,0,0" VerticalAlignment="Center"
                                 Fill="{Binding TcpServerModule.IsRunning, Converter={StaticResource BoolToBrushConverter}}"/>
                    </StackPanel>
                </Button>
                <Button Margin="0,0,0,5" Command="{Binding OpenTcpClientCommand}">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Client" VerticalAlignment="Center"/>
                        <Ellipse Width="12" Height="12" Margin="8,0,0,0" VerticalAlignment="Center"
                                 Fill="{Binding TcpClientModule.IsRunning, Converter={StaticResource BoolToBrushConverter}}"/>
                    </StackPanel>
                </Button>
                
                <TextBlock Text="Serial" FontWeight="SemiBold" Margin="0,5,0,5"/>
                <Button Content="Commands" Margin="0,0,0,5" Command="{Binding OpenSerialCommandsCommand}"/>
            </StackPanel>
        </Border>

        <!-- WORKSPACE -->
        <Border Grid.Row="0" Grid.Column="1" Background="White">
            <ContentControl Content="{Binding CurrentModule}" />
        </Border>

        <!-- CONSOLE -->
        <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
            Background="#1E1E1E">
            <TextBox 
                Foreground="LightGreen"
                Background="#1E1E1E"
                BorderThickness="0"
                FontFamily="Consolas"
                IsReadOnly="True"
                Text="{Binding ConsoleText}"
                TextWrapping="Wrap"
                VerticalScrollBarVisibility="Auto"
                Padding="10"
                AcceptsReturn="True"/>
        </Border>
    </Grid>
</Window>