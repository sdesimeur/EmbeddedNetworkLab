<Window x:Class="EmbeddedNetworkLab.UI.Windows.SerialCommandsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EmbeddedNetworkLab.UI.Windows"
        xmlns:converters="clr-namespace:EmbeddedNetworkLab.UI.Converters"
        mc:Ignorable="d"
        Title="SerialCommandsWindow" Height="800" Width="700"
        Closed="Window_Closed">

    <Window.Resources>
        <converters:BoolToBrushConverter x:Key="ConnectedBrush" TrueBrush="Green" FalseBrush="Red"/>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Configuration section -->
        <Border Grid.Row="0" Padding="8" Margin="0,0,0,8" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Background="White">
            <StackPanel>
                <TextBlock Text="Configuration" FontWeight="Bold" Margin="0,0,0,8" />

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Status:" VerticalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding StatusText}"
                               Foreground="{Binding IsConnected, Converter={StaticResource ConnectedBrush}}"
                               HorizontalAlignment="Center"/>
                </Grid>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Vertical" Margin="0,0,12,0">
                        <TextBlock Text="Port:" VerticalAlignment="Center" Margin="0,0,0,6"/>
                        <TextBlock Text="Baudrate:" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Vertical">
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <ComboBox MinWidth="200"
                                      Grid.Column="0"
                                      IsEditable="False"
                                      ItemsSource="{Binding AvailablePorts}"
                                      SelectedItem="{Binding SelectedPort}"
                                      IsEnabled="{Binding IsNotConnected}"
                                      ToolTip="Select a serial port" />

                            <Button Grid.Column="1"
                                    Width="34" Height="26"
                                    Margin="8,0,0,0"
                                    Command="{Binding RefreshPortsCommand}"
                                    IsEnabled="{Binding IsNotConnected}"
                                    ToolTip="Refresh COM ports"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Padding="0">
                                <TextBlock Text="↻" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Button>
                        </Grid>

                        <ComboBox MinWidth="200"
                                  IsEditable="False"
                                  ItemsSource="{Binding AvailableBaudRates}"
                                  SelectedItem="{Binding SelectedBaudRate}"
                                  IsEnabled="{Binding IsNotConnected}"
                                  ToolTip="Select baud rate" />
                    </StackPanel>

                    <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                        <Button Content="{Binding ConnectButtonLabel}"
                                Width="90" Margin="8,0,0,6"
                                Command="{Binding ConnectCommand}" />
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Command section -->
        <Border Grid.Row="1" Padding="8" Margin="0,0,0,8" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Background="White">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Commande" FontWeight="Bold" Grid.Column="0" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Load" Width="80" Margin="0,0,8,0"
                                Command="{Binding LoadCommandsCommand}"
                                ToolTip="Load name/value pairs from JSON" />
                        <Button Content="Save" Width="80"
                                Command="{Binding SaveCommandsCommand}"
                                ToolTip="Save name/value pairs to JSON" />
                    </StackPanel>
                </Grid>

                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="360">
                    <ItemsControl ItemsSource="{Binding Commands}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type local:SerialCommandRowViewModel}">
                                <StackPanel Orientation="Horizontal" Margin="0,4">
                                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                             MinWidth="140" Margin="0,0,8,0" VerticalAlignment="Center" />
                                    <TextBox Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                             MinWidth="260" Margin="0,0,8,0" VerticalAlignment="Center" />
                                    <Button Content="Send" Width="64"
                                            Command="{Binding SendCommand}" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <!-- Reception section -->
        <Border Grid.Row="2" Padding="8" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Background="White">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="Reception" FontWeight="Bold" Margin="0,0,0,8" />

                <TextBox Grid.Row="1"
                         Text="{Binding ReceptionText, Mode=OneWay}"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         VerticalAlignment="Stretch"
                         HorizontalAlignment="Stretch"
                         MinHeight="100" />
            </Grid>
        </Border>
    </Grid>
</Window>
