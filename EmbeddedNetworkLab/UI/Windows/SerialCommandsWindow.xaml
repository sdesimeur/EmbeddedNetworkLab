<Window x:Class="EmbeddedNetworkLab.UI.Windows.SerialCommandsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EmbeddedNetworkLab.UI.Windows"
        mc:Ignorable="d"
        Title="SerialCommandsWindow" Height="800" Width="700">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Configuration section -->
        <Border Grid.Row="0" Padding="8" Margin="0,0,0,8" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Background="White">
            <StackPanel>
                <TextBlock Text="Configuration" FontWeight="Bold" Margin="0,0,0,8" />

                <Grid Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Status:" VerticalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBlock x:Name="ConnectionStatusText" Text="Disconnected" Foreground="Red" HorizontalAlignment="Center"/>
                </Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Vertical" Margin="0,0,12,0">
                        <TextBlock Text="Port:" VerticalAlignment="Center" Margin="0,0,0,6"/>
                        <TextBlock Text="Baudrate:" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Vertical">
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <ComboBox x:Name="PortComboBox"
                                      MinWidth="200"
                                      Grid.Column="0"
                                      IsEditable="False"
                                      ToolTip="Select a serial port" />

                            <Button x:Name="RefreshPortsButton"
                                    Grid.Column="1"
                                    Width="34"
                                    Height="26"
                                    Margin="8,0,0,0"
                                    Click="RefreshPortsButton_Click"
                                    ToolTip="Refresh COM ports"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Padding="0">
                                <TextBlock Text="↻" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Button>
                        </Grid>

                        <ComboBox x:Name="BaudrateComboBox" MinWidth="200"
                                  IsEditable="False"
                                  ToolTip="Select baud rate">
                            <ComboBoxItem>115200</ComboBoxItem>
                            <ComboBoxItem>57600</ComboBoxItem>
                            <ComboBoxItem>38400</ComboBoxItem>
                            <ComboBoxItem>19200</ComboBoxItem>
                            <ComboBoxItem>9600</ComboBoxItem>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Vertical" HorizontalAlignment="Right">
                        <Button x:Name="ConnectButton" Content="Open" Width="90" Margin="8,0,0,6" Click="ConnectButton_Click"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Command section: 10 rows Name + Value + Send -->
        <Border Grid.Row="1" Padding="8" Margin="0,0,0,8" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Background="White">
            <StackPanel>
                <TextBlock Text="Commande" FontWeight="Bold" Margin="0,0,0,8" />
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="360">
                    <UniformGrid Columns="1" Rows="10" Margin="0" IsItemsHost="False">
                        <!-- Generate 10 rows manually -->
                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <!-- Removed PlaceholderText property, added ToolTip for hint -->
                            <TextBox x:Name="NameTextBox1" MinWidth="140" Margin="0,0,8,0" VerticalAlignment="Center" ToolTip="Name 1"/>
                            <TextBox x:Name="ValueTextBox1" MinWidth="260" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <Button x:Name="SendRowButton1" Content="Send" Width="64" Click="SendRowButton_Click" Tag="1" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <TextBox x:Name="NameTextBox2" MinWidth="140" Margin="0,0,8,0" VerticalAlignment="Center" ToolTip="Name 2"/>
                            <TextBox x:Name="ValueTextBox2" MinWidth="260" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <Button x:Name="SendRowButton2" Content="Send" Width="64" Click="SendRowButton_Click" Tag="2" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <TextBox x:Name="NameTextBox3" MinWidth="140" Margin="0,0,8,0" VerticalAlignment="Center" ToolTip="Name 3"/>
                            <TextBox x:Name="ValueTextBox3" MinWidth="260" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <Button x:Name="SendRowButton3" Content="Send" Width="64" Click="SendRowButton_Click" Tag="3" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <TextBox x:Name="NameTextBox4" MinWidth="140" Margin="0,0,8,0" VerticalAlignment="Center" ToolTip="Name 4"/>
                            <TextBox x:Name="ValueTextBox4" MinWidth="260" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <Button x:Name="SendRowButton4" Content="Send" Width="64" Click="SendRowButton_Click" Tag="4" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <TextBox x:Name="NameTextBox5" MinWidth="140" Margin="0,0,8,0" VerticalAlignment="Center" ToolTip="Name 5"/>
                            <TextBox x:Name="ValueTextBox5" MinWidth="260" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <Button x:Name="SendRowButton5" Content="Send" Width="64" Click="SendRowButton_Click" Tag="5" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <TextBox x:Name="NameTextBox6" MinWidth="140" Margin="0,0,8,0" VerticalAlignment="Center" ToolTip="Name 6"/>
                            <TextBox x:Name="ValueTextBox6" MinWidth="260" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <Button x:Name="SendRowButton6" Content="Send" Width="64" Click="SendRowButton_Click" Tag="6" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <TextBox x:Name="NameTextBox7" MinWidth="140" Margin="0,0,8,0" VerticalAlignment="Center" ToolTip="Name 7"/>
                            <TextBox x:Name="ValueTextBox7" MinWidth="260" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <Button x:Name="SendRowButton7" Content="Send" Width="64" Click="SendRowButton_Click" Tag="7" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <TextBox x:Name="NameTextBox8" MinWidth="140" Margin="0,0,8,0" VerticalAlignment="Center" ToolTip="Name 8"/>
                            <TextBox x:Name="ValueTextBox8" MinWidth="260" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <Button x:Name="SendRowButton8" Content="Send" Width="64" Click="SendRowButton_Click" Tag="8" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <TextBox x:Name="NameTextBox9" MinWidth="140" Margin="0,0,8,0" VerticalAlignment="Center" ToolTip="Name 9"/>
                            <TextBox x:Name="ValueTextBox9" MinWidth="260" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <Button x:Name="SendRowButton9" Content="Send" Width="64" Click="SendRowButton_Click" Tag="9" />
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,4">
                            <TextBox x:Name="NameTextBox10" MinWidth="140" Margin="0,0,8,0" VerticalAlignment="Center" ToolTip="Name 10"/>
                            <TextBox x:Name="ValueTextBox10" MinWidth="260" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <Button x:Name="SendRowButton10" Content="Send" Width="64" Click="SendRowButton_Click" Tag="10" />
                        </StackPanel>
                    </UniformGrid>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <!-- Reception section -->
        <Border Grid.Row="2" Padding="8" BorderBrush="#DDD" BorderThickness="1" CornerRadius="4" Background="White">
            <StackPanel>
                <TextBlock Text="Reception" FontWeight="Bold" Margin="0,0,0,8" />
                <TextBox x:Name="ReceptionTextBox"
                         IsReadOnly="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         VerticalAlignment="Stretch"
                         HorizontalAlignment="Stretch"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
